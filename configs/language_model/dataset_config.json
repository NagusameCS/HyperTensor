{
  "description": "Dedicated Language Model \u2014 trained exclusively on natural language data",
  "datasets": [
    {
      "name": "wikitext",
      "path": "wikitext",
      "split": "train",
      "max_samples": 50000,
      "format": "{text}",
      "filter": "language"
    },
    {
      "name": "bookcorpus",
      "path": "bookcorpus",
      "split": "train",
      "max_samples": 20000,
      "format": "{text}",
      "filter": "language"
    }
  ],
  "filters": {
    "exclude_patterns": [
      "\\b\\d{4,}\\b",
      "[+\\-*/=\\^]{2,}",
      "\\\\begin\\{",
      "\\\\frac\\{",
      "\\$.*\\$"
    ],
    "include_patterns": [
      "[a-zA-Z]{3,}"
    ]
  },
  "max_total_tokens": 3276800000
}